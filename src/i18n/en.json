        "sub": "Version 2.1 · effective June 1, 2026",
        "blocks": [
          {
            "type": "doc",
            "items": [
              {
                "h": "1. General provisions",
                "p": "donely.app is operated by Donely sp. z o.o., based in Warsaw. These Terms define the rules for using the service by clients and pros."
              },
              {
                "h": "2. Account",
                "p": "An account created with an email address is required. Sign-in uses a one-time code — no password."
              },
              {
                "h": "3. Bookings and quotes",
                "p": "Booking a slot or accepting a quote forms a service agreement between the client and the pro. Donely intermediates settlement and documentation."
              },
              {
                "h": "4. Payments and receipts",
                "p": "Payment is made after the service. Donely issues a receipt or invoice on the pro's behalf and settles applicable taxes under current law."
              },
              {
                "h": "5. Cancellations",
                "p": "Free cancellation is available up to 24 hours before the appointment. Detailed fees for later cancellations are set out in the Pricing."
              },
              {
                "h": "6. Complaints",
                "p": "Complaints can be filed in the app or at pomoc@donely.app within 14 days of the job. We respond within 14 business days."
              }
            ]
          }
        ]
      },
      "prywatnosc": {
        "title": "Privacy Policy",
        "sub": "Last updated: June 1, 2026",
        "blocks": [
          {
            "type": "doc",
            "items": [
              {
                "h": "1. Data controller",
                "p": "The controller of your data is Donely sp. z o.o., Prosta 20, 00-850 Warsaw. Contact: prywatnosc@donely.app."
              },
              {
                "h": "2. What we collect",
                "p": "Email address, booking data, location (with consent) and pros' billing data — only as needed to provide the service."
              },
              {
                "h": "3. Purpose",
                "p": "Fulfilling bookings, issuing accounting documents, pros' tax settlement, service security and communication."
              },
              {
                "h": "4. Sharing",
                "p": "We share data between client and pro as needed for the job, and with payment and accounting providers."
              },
              {
                "h": "5. Your rights",
                "p": "You have the right to access, rectify, erase and port your data, and to object. Requests: prywatnosc@donely.app."
              }
            ]
          }
        ]
      }
    }
