      "onas": {
        "title": "About us",
        "sub": "We're building the simplest way to find a trusted pro — and to earn from your skills, legally.",
        "blocks": [
          {
            "type": "doc",
            "items": [
              {
                "h": "Our mission",
                "p": "Millions of small jobs are settled off the books, with no receipt and no protection for either side. Donely changes that with one app: clients pay after the job and get a receipt, and pros never worry about taxes — we settle them."
              },
              {
                "h": "How we work",
                "p": "We're a Warsaw-based team with marketplace, fintech and services experience. We believe in simple products, transparent rules and technology that stays out of the way."
              }
            ]
          },
          {
            "type": "cards",
            "items": [
              {
                "icon": "🤝",
                "t": "Trust",
                "d": "We verify pros' identity, and reviews come only from real jobs."
              },
              {
                "icon": "⚖️",
                "t": "Legality",
                "d": "Every job ends with a receipt or invoice. Taxes settled — automatically."
              },
              {
                "icon": "⚡",
                "t": "Simplicity",
                "d": "From problem to booking in a minute. Zero paperwork on both sides."
              }
            ]
          }
        ]
      },
