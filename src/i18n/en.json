      "pomoc": {
        "title": "Help center",
        "sub": "Common questions about bookings, payments and your account.",
        "blocks": [
          {
            "type": "faq",
            "items": [
              {
                "q": "How does pay-after-the-job work?",
                "a": "You book with no prepayment. After the job is done you pay directly — cash, card or BLIK — and Donely automatically issues a receipt or invoice."
              },
              {
                "q": "Will I get a receipt or invoice?",
                "a": "Yes, always. The document lands in your email after every completed job. Companies can add VAT details in their profile."
              },
              {
                "q": "How do I become a pro on Donely?",
                "a": "Create an account, pass identity verification and set up your services with prices. You can usually take your first jobs within 24 hours."
              },
              {
                "q": "What if the service doesn't happen?",
                "a": "You pay nothing. Report it in the app — we'll help find a new time or another pro."
              },
              {
                "q": "How does pro verification work?",
                "a": "We check an ID document and billing details, and the “Verified” badge goes only to vetted profiles. Reviews come exclusively from real jobs."
              }
            ]
          },
          {
            "type": "doc",
            "items": [
              {
                "h": "Didn't find an answer?",
                "p": "Email pomoc@donely.app or use the in-app chat (Mon–Sat 8:00–20:00)."
              }
            ]
          }
        ]
      },
